function loadComponents(){
  const type=document.getElementById('machine-type').value;
  const cap=document.getElementById('capacity').value;
  selectedComponents=[];updateTotal();
  if(!type){document.getElementById('comp-area').innerHTML='<div class="no-comp">Select a Plant Type above to load available components</div>';return;}
  const sections=COMPONENTS[type];let html='';
  Object.keys(sections).forEach(section=>{
    html+=`<div class="comp-section"><div class="comp-section-label">${section}</div>
    <table class="comp-table"><thead><tr>
      <th style="width:36px">Select</th><th style="width:100px">Series</th>
      <th>Machine / Description</th><th style="width:65px;text-align:center">Qty</th>
      <th style="width:110px;text-align:right">Unit Price</th><th style="width:110px;text-align:right">Amount</th>
    </tr></thead><tbody>`;
    sections[section].forEach(comp=>{
      const sc=`${comp.id}-${cap}TPH`,k=`${section}__${comp.id}__${cap}`;
      html+=`<tr>
        <td><input type="checkbox" class="comp-check" id="chk-${k}" onchange="toggleComp('${k}','${section}','${comp.id}','${comp.name}','${sc}','${comp.desc}',${comp.price},'${comp.motor}','${comp.size}','${comp.type}','${comp.screens}')"></td>
        <td><span class="series-tag">${sc}</span></td>
        <td><div style="font-weight:500;font-size:13px">${comp.name}</div>
          <div style="font-size:11px;color:#8a9ab0;margin-top:2px">${comp.desc}</div>
          <div style="font-size:10px;color:#aaa;margin-top:2px">Motor: ${comp.motor} | Size: ${comp.size} | ${comp.type}</div></td>
        <td style="text-align:center"><input type="number" class="qty-input" id="qty-${k}" value="1" min="1" max="99" onchange="updateQty('${k}',this.value)"></td>
        <td style="text-align:right"><span class="price-tag">&#8377;${fmtN(comp.price)}</span></td>
        <td style="text-align:right"><span class="amt-tag" id="amt-${k}">—</span></td>
      </tr>`;
    });
    html+=`</tbody></table></div>`;
  });
  document.getElementById('comp-area').innerHTML=html;
}

function toggleComp(k,section,id,name,series,desc,price,motor,size,type,screens){
  const checked=document.getElementById('chk-'+k).checked;
  const qty=parseInt(document.getElementById('qty-'+k).value)||1;
  if(checked){selectedComponents.push({k,section,id,name,series,desc,price:+price,motor,size,type,screens,qty});document.getElementById('amt-'+k).textContent='₹'+fmtN(+price*qty);}
  else{selectedComponents=selectedComponents.filter(c=>c.k!==k);document.getElementById('amt-'+k).textContent='—';}
  updateTotal();
}

function updateQty(k,val){
  const qty=Math.max(1,parseInt(val)||1);
  document.getElementById('qty-'+k).value=qty;
  const c=selectedComponents.find(c=>c.k===k);
  if(c){c.qty=qty;document.getElementById('amt-'+k).textContent='₹'+fmtN(c.price*qty);}
  updateTotal();
}

function updateTotal(){
  const isTurnkey=document.getElementById('turnkey-toggle').checked;
  const slider=document.getElementById('turnkey-slider');
  slider.style.background=isTurnkey?'#1a7a4a':'#ccc';
  document.getElementById('turnkey-badge').style.display=isTurnkey?'inline-block':'none';
  document.getElementById('erection-breakdown').style.display=isTurnkey?'block':'none';

  const fb1=parseInt(document.getElementById('f-b1').value)||0;
  const fb2=parseInt(document.getElementById('f-b2').value)||0;
  const fb3=parseInt(document.getElementById('f-b3').value)||0;
  const fb4=parseInt(document.getElementById('f-b4').value)||0;
  const erectionB=isTurnkey?(fb1+fb2+fb3+fb4):0;
  const totalA=selectedComponents.reduce((s,c)=>s+c.price*c.qty,0);
  const grandTotal=totalA+erectionB;

  if(isTurnkey){
    document.getElementById('erection-b-display').textContent=fmtINR(erectionB);
    document.getElementById('erection-label-display').textContent='+ Total B (Erection) = '+fmtINR(erectionB);
  } else {
    document.getElementById('erection-label-display').textContent='Supply only — erection not included';
  }

  document.getElementById('grand-total').textContent='₹ '+fmtN(grandTotal);
  document.getElementById('items-count').textContent=selectedComponents.length+' item(s) | '+(isTurnkey?'Turnkey A+B':'Supply Only A');
}

function resetForm(){
  ['cust-name','cust-contact','cust-phone','cust-loc','cust-email'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('machine-type').value='';
  document.getElementById('capacity').value='4';
  document.getElementById('sel-sp').value='';
  document.getElementById('sp-preview-box').style.display='none';
  document.getElementById('turnkey-toggle').checked=false;
  ['f-b1','f-b2','f-b3','f-b4'].forEach(id=>document.getElementById(id).value='');
  selectedComponents=[];updateTotal();
  document.getElementById('comp-area').innerHTML='<div class="no-comp">Select a Plant Type above to load available components</div>';
  document.getElementById('quot-preview').style.display='none';
}

