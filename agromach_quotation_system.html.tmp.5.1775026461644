<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AgroMach — Quotation System</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<style>
:root{
  --green:#1a7a4a;--green-light:#e8f5ee;--green-mid:#2d9e63;--accent:#f0a500;
  --dark:#0f1923;--dark2:#1c2936;--dark3:#243447;
  --text:#1a2535;--text2:#4a5568;--text3:#8a9ab0;
  --border:#dde3ed;--bg:#f0f3f8;--white:#ffffff;--red:#e53e3e;
  --sidebar-w:210px;--radius:10px;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;display:flex}
.sidebar{width:var(--sidebar-w);background:var(--dark);min-height:100vh;display:flex;flex-direction:column;flex-shrink:0;position:sticky;top:0;height:100vh}
.sidebar-logo{padding:22px 18px 18px;border-bottom:1px solid var(--dark3)}
.logo-text{font-size:20px;font-weight:600;color:#fff}
.logo-text span{color:var(--green-mid)}
.logo-sub{font-size:10px;color:var(--text3);margin-top:2px;font-family:'IBM Plex Mono',monospace}
.sidebar-nav{padding:14px 10px;flex:1}
.nav-label{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:0.1em;margin:14px 8px 6px;font-family:'IBM Plex Mono',monospace}
.nav-item{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:8px;color:#a0aec0;font-size:13px;cursor:pointer;transition:all 0.15s;margin-bottom:2px;font-weight:400;border:none;background:none;width:100%;text-align:left}
.nav-item:hover{background:var(--dark3);color:#fff}
.nav-item.active{background:var(--green);color:#fff;font-weight:500}
.nav-icon{width:15px;height:15px;flex-shrink:0}
.sidebar-footer{padding:14px 18px;border-top:1px solid var(--dark3);font-size:10px;color:var(--text3);font-family:'IBM Plex Mono',monospace;line-height:1.5}
.main{flex:1;display:flex;flex-direction:column;min-width:0}
.topbar{background:var(--white);border-bottom:1px solid var(--border);padding:0 28px;height:58px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:10}
.page-title{font-size:15px;font-weight:600;color:var(--text)}
.breadcrumb{font-size:12px;color:var(--text3)}
.avatar{width:32px;height:32px;border-radius:50%;background:var(--green);color:#fff;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600}
.date-badge{font-size:11px;color:var(--text3);font-family:'IBM Plex Mono',monospace;background:var(--bg);padding:5px 10px;border-radius:6px}
.content{padding:22px 28px;flex:1}
.page{display:none}.page.active{display:block}

/* STATS */
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:22px}
.stat-card{background:var(--white);border-radius:var(--radius);border:1px solid var(--border);padding:15px 17px}
.stat-label{font-size:11px;color:var(--text3);text-transform:uppercase;letter-spacing:0.07em;margin-bottom:5px}
.stat-val{font-size:23px;font-weight:600;color:var(--text)}
.stat-sub{font-size:11px;color:var(--text3);margin-top:3px}

/* FORM CARD */
.form-card{background:var(--white);border-radius:var(--radius);border:1px solid var(--border);overflow:hidden;margin-bottom:20px}
.form-card-header{padding:15px 22px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.form-card-title{font-size:14px;font-weight:600;color:var(--text)}
.form-card-sub{font-size:12px;color:var(--text3);margin-top:1px}
.form-body{padding:22px}
.form-section-title{font-size:11px;font-weight:600;color:var(--green);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:14px;padding-bottom:8px;border-bottom:2px solid var(--green-light);font-family:'IBM Plex Mono',monospace}
.form-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:13px;margin-bottom:20px}
.form-grid-2{display:grid;grid-template-columns:1fr 1fr;gap:13px;margin-bottom:20px}
.field label{display:block;font-size:12px;font-weight:500;color:var(--text2);margin-bottom:5px}
.field input,.field select{width:100%;padding:9px 12px;border:1px solid var(--border);border-radius:7px;font-size:13px;color:var(--text);background:var(--white);font-family:'DM Sans',sans-serif;transition:border-color 0.15s}
.field input:focus,.field select:focus{outline:none;border-color:var(--green-mid)}
.field input::placeholder{color:var(--text3)}

/* COMPONENTS */
.comp-section{margin-bottom:18px}
.comp-section-label{font-size:12px;font-weight:600;color:var(--text2);margin-bottom:8px;padding:6px 10px;background:var(--bg);border-radius:6px;border-left:3px solid var(--green-mid)}
.comp-table{width:100%;border-collapse:collapse;font-size:13px}
.comp-table th{text-align:left;padding:8px 12px;background:var(--bg);font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:0.06em;border-bottom:1px solid var(--border)}
.comp-table td{padding:9px 12px;border-bottom:1px solid var(--border);vertical-align:middle}
.comp-table tr:last-child td{border-bottom:none}
.comp-table tr:hover td{background:#fafbfc}
.comp-check{width:16px;height:16px;accent-color:var(--green);cursor:pointer}
.qty-input{width:58px;padding:5px 8px;border:1px solid var(--border);border-radius:5px;font-size:13px;text-align:center;color:var(--text);font-family:'DM Sans',sans-serif}
.qty-input:focus{outline:none;border-color:var(--green-mid)}
.price-tag{font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--text2)}
.amt-tag{font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--green);font-weight:500}
.series-tag{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--text3)}

/* TOTAL BOX */
.total-box{background:var(--dark);border-radius:8px;padding:15px 20px;margin-top:16px;display:flex;align-items:center;justify-content:space-between}
.total-val{font-size:22px;font-weight:700;color:#fff;font-family:'IBM Plex Mono',monospace}

/* BUTTONS */
.btn-row{display:flex;gap:10px;margin-top:20px;justify-content:flex-end}
.btn{padding:9px 20px;border-radius:7px;font-size:13px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;border:none;transition:all 0.15s}
.btn-outline{background:var(--white);border:1px solid var(--border);color:var(--text2)}
.btn-outline:hover{background:var(--bg)}
.btn-primary{background:var(--green);color:#fff}
.btn-primary:hover{background:var(--green-mid)}
.btn-accent{background:var(--accent);color:#fff}
.btn-accent:hover{background:#d4920a}
.btn-sm{padding:5px 12px;font-size:12px;border-radius:6px}
.btn-danger{background:#fff0f0;color:var(--red);border:1px solid #ffd0d0}
.btn-danger:hover{background:#ffe0e0}
.badge{display:inline-block;font-size:10px;padding:2px 8px;border-radius:12px;font-weight:600}
.badge-green{background:var(--green-light);color:var(--green)}
.badge-blue{background:#e6f1fb;color:#0c447c}
.badge-orange{background:#fff8e6;color:#b07800}
.no-comp{text-align:center;padding:2rem;color:var(--text3);font-size:13px}

/* SALES PERSON CARDS */
.sp-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:22px}
.sp-card{background:var(--white);border-radius:var(--radius);border:1px solid var(--border);padding:18px;cursor:pointer;transition:all 0.15s;position:relative}
.sp-card:hover{border-color:var(--green-mid);box-shadow:0 2px 12px rgba(29,158,117,0.1)}
.sp-avatar{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:700;color:#fff;margin-bottom:12px;flex-shrink:0}
.sp-name{font-size:14px;font-weight:600;color:var(--text);margin-bottom:2px}
.sp-desig{font-size:12px;color:var(--text3);margin-bottom:12px}
.sp-stats{display:flex;gap:14px}
.sp-stat{text-align:center}
.sp-stat-val{font-size:18px;font-weight:700;color:var(--text)}
.sp-stat-label{font-size:10px;color:var(--text3);text-transform:uppercase;letter-spacing:0.05em}
.sp-phone{font-size:11px;color:var(--text3);margin-top:10px;font-family:'IBM Plex Mono',monospace}
.sp-card-actions{position:absolute;top:12px;right:12px;display:flex;gap:4px;opacity:0;transition:opacity 0.15s}
.sp-card:hover .sp-card-actions{opacity:1}
.icon-btn{width:26px;height:26px;border-radius:5px;border:1px solid var(--border);background:var(--white);cursor:pointer;display:flex;align-items:center;justify-content:center}
.icon-btn:hover{background:var(--bg)}
.icon-btn.del:hover{background:#fff0f0;border-color:#ffd0d0}

/* QUOTATION TABLE */
.q-list-table{width:100%;border-collapse:collapse;font-size:13px}
.q-list-table th{text-align:left;font-size:11px;color:var(--text3);font-weight:600;padding:8px 12px;border-bottom:1px solid var(--border);text-transform:uppercase;letter-spacing:0.05em;background:var(--bg)}
.q-list-table td{padding:10px 12px;border-bottom:1px solid var(--border);color:var(--text);vertical-align:middle}
.q-list-table tr:last-child td{border-bottom:none}
.q-list-table tr:hover td{background:#fafcfa}
.q-row-btn{padding:4px 10px;border-radius:5px;border:1px solid var(--green);background:var(--white);color:var(--green);font-size:11px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif}
.q-row-btn:hover{background:var(--green-light)}
.status-dot{display:inline-block;width:7px;height:7px;border-radius:50%;margin-right:5px}

/* MODAL */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:200;align-items:center;justify-content:center}
.modal-overlay.open{display:flex}
.modal{background:var(--white);border-radius:14px;padding:24px;width:100%;max-width:440px;box-shadow:0 8px 32px rgba(0,0,0,0.12)}
.modal h3{font-size:15px;font-weight:700;margin-bottom:16px;color:var(--text)}
.modal-field{margin-bottom:13px}
.modal-field label{display:block;font-size:12px;font-weight:500;color:var(--text2);margin-bottom:4px}
.modal-field input,.modal-field select{width:100%;padding:9px 12px;border:1px solid var(--border);border-radius:7px;font-size:13px;color:var(--text);font-family:'DM Sans',sans-serif}
.modal-field input:focus,.modal-field select:focus{outline:none;border-color:var(--green-mid)}
.modal-btns{display:flex;gap:10px;margin-top:18px}
.mbtn{flex:1;padding:9px;border-radius:7px;border:1px solid var(--border);font-size:13px;font-weight:600;cursor:pointer;background:var(--white);color:var(--text2);font-family:'DM Sans',sans-serif}
.mbtn:hover{background:var(--bg)}
.mbtn-p{background:var(--green);color:#fff;border-color:var(--green)}
.mbtn-p:hover{background:var(--green-mid)}

/* SETTINGS */
.settings-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.settings-card{background:var(--white);border-radius:var(--radius);border:1px solid var(--border);overflow:hidden}
.settings-full{grid-column:1/-1}
.settings-card-header{padding:13px 18px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px}
.settings-card-icon{width:28px;height:28px;border-radius:7px;background:var(--green-light);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.settings-card-title{font-size:13px;font-weight:600;color:var(--text)}
.settings-card-body{padding:16px 18px}
.sfield{margin-bottom:12px}
.sfield:last-child{margin-bottom:0}
.sfield label{display:block;font-size:11px;font-weight:500;color:var(--text3);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:4px}
.sfield input,.sfield textarea{width:100%;padding:8px 11px;border:1px solid var(--border);border-radius:7px;font-size:13px;color:var(--text);background:var(--white);font-family:'DM Sans',sans-serif}
.sfield input:focus,.sfield textarea:focus{outline:none;border-color:var(--green-mid)}
.sfield textarea{resize:vertical;min-height:60px}
.erection-row{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.erection-row label{font-size:12px;color:var(--text2);flex:1}
.erection-row input{width:130px;padding:7px 10px;border:1px solid var(--border);border-radius:6px;font-size:13px;color:var(--text);font-family:'IBM Plex Mono',monospace;text-align:right}
.erection-row input:focus{outline:none;border-color:var(--green-mid)}
.erection-total{background:var(--dark);border-radius:7px;padding:10px 14px;display:flex;justify-content:space-between;align-items:center;margin-top:10px}
.save-bar{padding:14px 22px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:8px;background:var(--bg)}

/* SP SETTINGS TABLE */
.sp-settings-table{width:100%;border-collapse:collapse;font-size:13px}
.sp-settings-table th{text-align:left;font-size:11px;color:var(--text3);font-weight:600;padding:8px 12px;border-bottom:1px solid var(--border);background:var(--bg);text-transform:uppercase;letter-spacing:0.05em}
.sp-settings-table td{padding:10px 12px;border-bottom:1px solid var(--border);vertical-align:middle}
.sp-settings-table tr:last-child td{border-bottom:none}
.color-dot{width:14px;height:14px;border-radius:50%;display:inline-block}

/* QUOT PREVIEW */
#quot-preview{display:none;margin-top:22px}
.quot-wrapper{background:var(--white);border-radius:var(--radius);border:1px solid var(--border);overflow:hidden}
.quot-actions{padding:13px 22px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:var(--bg)}

/* QUOTATION DOC */
#quotation-doc{padding:32px 36px;font-family:'DM Sans',Arial,sans-serif;font-size:13px;color:#111;background:#fff;max-width:900px;margin:0 auto}
.q-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:20px;padding-bottom:16px;border-bottom:3px solid #1a7a4a}
.q-company-name{font-size:24px;font-weight:700;color:#1a7a4a}
.q-company-sub{font-size:11px;color:#555;margin-top:4px;line-height:1.6}
.q-title{font-size:26px;font-weight:700;color:#0f1923;letter-spacing:2px;text-transform:uppercase}
.q-no-block{margin-top:6px;font-size:12px;color:#555;line-height:1.6}
.q-meta{display:grid;grid-template-columns:1fr 1fr;margin-bottom:14px}
.q-to-box{background:#f5f8ff;padding:13px 15px;border:1px solid #dde3ed;border-right:none;border-radius:8px 0 0 8px}
.q-info-box{background:#f5f8ff;padding:13px 15px;border:1px solid #dde3ed;border-radius:0 8px 8px 0}
.q-meta-label{font-size:10px;color:#888;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:2px}
.q-meta-val{font-size:13px;font-weight:600;color:#111;margin-bottom:5px}
.q-meta-row{font-size:12px;color:#444;margin-bottom:2px}
.q-note{background:#fff8e6;border:1px solid #f0a500;border-radius:6px;padding:7px 14px;font-size:11px;color:#7a5800;font-weight:500;margin-bottom:13px;text-align:center}
.q-subject{font-size:13px;font-weight:600;color:#111;margin-bottom:14px;text-align:center;padding:9px;background:#e8f5ee;border-radius:6px;border:1px solid #b2d8c2}
.q-opening{font-size:12px;color:#444;margin-bottom:14px;line-height:1.7}
.q-section-head{background:#1a7a4a;color:#fff;padding:7px 10px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.1em}
.q-tbl{width:100%;border-collapse:collapse}
.q-tbl thead th{background:#2d3748;color:#fff;padding:8px 10px;font-size:11px;text-align:left;font-weight:600;text-transform:uppercase;letter-spacing:0.06em}
.q-tbl tbody td{padding:8px 10px;font-size:12px;border-bottom:1px solid #e2e8f0;color:#222;vertical-align:top}
.q-tbl tbody tr:nth-child(even) td{background:#f9fafb}
.q-tbl td.mono{font-family:'IBM Plex Mono',monospace;font-size:11px;color:#555}
.q-tbl td.right{text-align:right;font-family:'IBM Plex Mono',monospace;font-size:12px}
.q-tbl td.center{text-align:center}
.q-spec{font-size:10px;color:#777;margin-top:3px;line-height:1.5}
.tbl-border{border:1px solid #c8d6e5}
.q-summary{margin-top:14px;border:1px solid #c8d6e5;border-radius:8px;overflow:hidden}
.q-sum-row{display:flex;justify-content:space-between;align-items:center;padding:8px 15px;border-bottom:1px solid #e2e8f0;font-size:12px}
.q-sum-row:last-child{border-bottom:none}
.q-sum-label{color:#555}
.q-sum-val{font-family:'IBM Plex Mono',monospace;font-weight:600;color:#111}
.q-sum-total{background:#1a7a4a;padding:11px 15px;display:flex;justify-content:space-between;align-items:center}
.q-sum-total .q-sum-label{color:#9FE1CB;font-weight:600;font-size:13px}
.q-sum-total .q-sum-val{color:#fff;font-size:17px}
.q-terms-title{font-size:12px;font-weight:700;color:#1a7a4a;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:10px;padding-bottom:5px;border-bottom:2px solid #e8f5ee;margin-top:18px}
.q-terms-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px}
.q-term-item{font-size:11px;color:#444;padding:7px 10px;background:#f5f8ff;border-radius:5px;border-left:3px solid #1a7a4a}
.q-term-key{font-weight:600;color:#1a7a4a;margin-bottom:2px}
.q-sign{margin-top:22px;padding-top:14px;border-top:1px solid #e2e8f0;display:flex;justify-content:space-between;align-items:flex-end}
.sp-ref-box{background:#f0f7f3;border:1px solid #b2d8c2;border-radius:7px;padding:9px 14px;margin-bottom:14px;font-size:12px;color:#1a7a4a;display:flex;align-items:center;gap:10px}
.sp-ref-avatar{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:#fff;flex-shrink:0}
/* Toggle switch knob */
#turnkey-slider::before{content:'';position:absolute;height:18px;width:18px;left:3px;bottom:3px;background:#fff;border-radius:50%;transition:0.2s}
#turnkey-toggle:checked + #turnkey-slider::before{transform:translateX(20px)}

/* ===== LOGIN LOCK SCREEN ===== */
.login-overlay{position:fixed;inset:0;z-index:9999;background:var(--dark);display:flex;align-items:center;justify-content:center;transition:opacity 0.5s,transform 0.5s}
.login-overlay.hide{opacity:0;transform:scale(1.05);pointer-events:none}
.login-box{background:var(--dark2);border:1px solid var(--dark3);border-radius:16px;padding:40px 36px 36px;width:100%;max-width:400px;box-shadow:0 20px 60px rgba(0,0,0,0.5);text-align:center}
.login-logo{font-size:28px;font-weight:700;color:#fff;margin-bottom:4px}
.login-logo span{color:var(--green-mid)}
.login-subtitle{font-size:11px;color:var(--text3);font-family:'IBM Plex Mono',monospace;margin-bottom:30px;letter-spacing:0.08em}
.login-lock-icon{width:56px;height:56px;border-radius:50%;background:var(--dark3);display:flex;align-items:center;justify-content:center;margin:0 auto 24px}
.login-lock-icon svg{width:26px;height:26px;stroke:#fff;fill:none;stroke-width:2}
.login-field{margin-bottom:16px;text-align:left}
.login-field label{display:block;font-size:11px;font-weight:600;color:var(--text3);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:6px;font-family:'IBM Plex Mono',monospace}
.login-field input{width:100%;padding:12px 14px;border:1px solid var(--dark3);border-radius:8px;font-size:14px;color:#fff;background:var(--dark);font-family:'DM Sans',sans-serif;transition:border-color 0.2s}
.login-field input:focus{outline:none;border-color:var(--green-mid);box-shadow:0 0 0 3px rgba(45,158,99,0.15)}
.login-field input::placeholder{color:#4a5568}
.login-btn{width:100%;padding:13px;border:none;border-radius:8px;background:var(--green);color:#fff;font-size:14px;font-weight:600;cursor:pointer;font-family:'DM Sans',sans-serif;transition:background 0.2s;margin-top:6px}
.login-btn:hover{background:var(--green-mid)}
.login-btn:active{transform:scale(0.98)}
.login-error{color:var(--red);font-size:12px;margin-top:12px;min-height:18px;font-weight:500}
.login-footer{margin-top:28px;font-size:10px;color:#4a5568;font-family:'IBM Plex Mono',monospace}
.app-wrapper{display:none}
.app-wrapper.unlocked{display:flex;width:100%}
</style>
</head>
<body>

<!-- ===== LOGIN LOCK SCREEN ===== -->
<div class="login-overlay" id="loginOverlay">
  <div class="login-box">
    <div class="login-lock-icon">
      <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/><circle cx="12" cy="16" r="1"/></svg>
    </div>
    <div class="login-logo">Agro<span>Mach</span></div>
    <div class="login-subtitle">Quotation Management System</div>
    <div class="login-field">
      <label>User ID</label>
      <input type="text" id="loginId" placeholder="Enter your ID" autocomplete="off" onkeydown="if(event.key==='Enter')document.getElementById('loginPass').focus()">
    </div>
