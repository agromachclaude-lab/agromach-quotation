function generateQuotation(){
  const custName=document.getElementById('cust-name').value.trim();
  const machineType=document.getElementById('machine-type').value;
  const spId=document.getElementById('sel-sp').value;
  if(!custName){alert('Please enter Customer Name.');return;}
  if(!machineType){alert('Please select a Machine Type.');return;}
  if(!spId){alert('Please assign a Sales Person.');return;}
  if(!selectedComponents.length){alert('Please select at least one component.');return;}

  const isTurnkey=document.getElementById('turnkey-toggle').checked;
  const fb1=parseInt(document.getElementById('f-b1').value)||0;
  const fb2=parseInt(document.getElementById('f-b2').value)||0;
  const fb3=parseInt(document.getElementById('f-b3').value)||0;
  const fb4=parseInt(document.getElementById('f-b4').value)||0;
  const capacity=document.getElementById('capacity').value;
  const totalA=selectedComponents.reduce((s,c)=>s+c.price*c.qty,0);
  const erectionB=isTurnkey?(fb1+fb2+fb3+fb4):0;
  const totalAB=totalA+erectionB;
  const quotNo=autoQNo();const dateStr=todayFmt();

  const qData={
    id:'q_'+Date.now(),quotNo,dateStr,
    custName,custContact:document.getElementById('cust-contact').value.trim(),
    custPhone:document.getElementById('cust-phone').value.trim(),
    custLoc:document.getElementById('cust-loc').value.trim(),
    machineType,capacity,spId,
    components:JSON.parse(JSON.stringify(selectedComponents)),
    totalA,totalAB,isTurnkey,
    b1:fb1,b2:fb2,b3:fb3,b4:fb4,
    createdAt:Date.now()
  };
  savedQuotations.push(qData);
  persist();

  const html=buildQuotHTML(qData);
  document.getElementById('quotation-doc').innerHTML=html;
  document.getElementById('quot-preview').style.display='block';
  document.getElementById('quot-preview').scrollIntoView({behavior:'smooth'});
}

function viewSavedQuotation(qId){
  const q=savedQuotations.find(x=>x.id===qId);
  if(!q) return;
  document.getElementById('view-quot-doc').innerHTML=buildQuotHTML(q);
  document.getElementById('view-quot-modal').classList.add('open');
  window._viewingQuotId=qId;
}

function closeViewModal(){document.getElementById('view-quot-modal').classList.remove('open')}

function downloadViewedPDF(){
  const el=document.getElementById('view-quot-doc');
  const q=savedQuotations.find(x=>x.id===window._viewingQuotId);
  const fname=`Quotation_${(q?q.custName:'Customer').replace(/\s+/g,'_')}_${q?q.quotNo:'Q'}.pdf`;
  html2pdf().set({margin:[8,6,8,6],filename:fname,image:{type:'jpeg',quality:0.97},html2canvas:{scale:2,useCORS:true},jsPDF:{unit:'mm',format:'a4',orientation:'portrait'},pagebreak:{mode:['avoid-all','css','legacy']}}).from(el).save();
}

function downloadPDF(){
  const el=document.getElementById('quotation-doc');
  const custName=document.getElementById('cust-name').value.trim().replace(/\s+/g,'_')||'Customer';
  const d=new Date();
  const fname=`Quotation_${custName}_${d.getFullYear()}${String(d.getMonth()+1).padStart(2,'0')}${String(d.getDate()).padStart(2,'0')}.pdf`;
  html2pdf().set({margin:[8,6,8,6],filename:fname,image:{type:'jpeg',quality:0.97},html2canvas:{scale:2,useCORS:true},jsPDF:{unit:'mm',format:'a4',orientation:'portrait'},pagebreak:{mode:['avoid-all','css','legacy']}}).from(el).save();
}

