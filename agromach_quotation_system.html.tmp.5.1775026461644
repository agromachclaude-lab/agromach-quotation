function openSpModal(editId){
  document.getElementById('sp-edit-id').value='';
  document.getElementById('sp-m-name').value='';
  document.getElementById('sp-m-desig').value='';
  document.getElementById('sp-m-phone').value='';
  document.getElementById('sp-m-color').value='#1a7a4a';
  document.getElementById('sp-modal-title').textContent='Add Sales Person';
  if(editId){
    const sp=salesPersons.find(s=>s.id===editId);
    if(sp){
      document.getElementById('sp-edit-id').value=sp.id;
      document.getElementById('sp-m-name').value=sp.name;
      document.getElementById('sp-m-desig').value=sp.desig||'';
      document.getElementById('sp-m-phone').value=sp.phone||'';
      document.getElementById('sp-m-color').value=sp.color||'#1a7a4a';
      document.getElementById('sp-modal-title').textContent='Edit Sales Person';
    }
  }
  document.getElementById('sp-modal').classList.add('open');
}

function closeSpModal(){document.getElementById('sp-modal').classList.remove('open')}

function saveSp(){
  const name=document.getElementById('sp-m-name').value.trim();
  if(!name){alert('Name is required!');return;}
  const editId=document.getElementById('sp-edit-id').value;
  const sp={
    id:editId||('sp_'+Date.now()),
    name,
    desig:document.getElementById('sp-m-desig').value.trim()||'Sales Executive',
    phone:document.getElementById('sp-m-phone').value.trim(),
    color:document.getElementById('sp-m-color').value
  };
  if(editId){
    const idx=salesPersons.findIndex(s=>s.id===editId);
    if(idx>=0) salesPersons[idx]=sp;
  } else {
    salesPersons.push(sp);
  }
  persist();
  closeSpModal();
  renderSpSettingsTable();
  populateSpDropdown();
  renderDashboard();
}

function deleteSp(id){
  if(!confirm('Delete this sales person? Their quotations will remain but become unassigned.')) return;
  salesPersons=salesPersons.filter(s=>s.id!==id);
  persist();
  renderSpSettingsTable();
  populateSpDropdown();
  renderDashboard();
}

function editSp(id){openSpModal(id);}

function renderSpSettingsTable(){
  const tbody=document.getElementById('sp-settings-tbody');
  const empty=document.getElementById('sp-settings-empty');
  if(!salesPersons.length){tbody.innerHTML='';empty.style.display='block';return;}
  empty.style.display='none';
  tbody.innerHTML=salesPersons.map(sp=>{
    const cnt=savedQuotations.filter(q=>q.spId===sp.id).length;
    const initials=sp.name.split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2);
    return `<tr>
      <td><div style="width:30px;height:30px;border-radius:50%;background:${sp.color};display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff">${initials}</div></td>
      <td style="font-weight:500">${sp.name}</td>
      <td style="color:var(--text3)">${sp.desig||'—'}</td>
      <td style="font-family:'IBM Plex Mono',monospace;font-size:12px">${sp.phone||'—'}</td>
      <td><span class="badge badge-green">${cnt} quotation(s)</span></td>
      <td>
        <div style="display:flex;gap:6px">
          <button class="btn btn-outline btn-sm" onclick="openSpModal('${sp.id}')">Edit</button>
          <button class="btn btn-danger btn-sm" onclick="deleteSp('${sp.id}')">Delete</button>
        </div>
      </td>
    </tr>`;
  }).join('');
}

function populateSpDropdown(){
  const sel=document.getElementById('sel-sp');
  const cur=sel.value;
  sel.innerHTML='<option value="">— Select Sales Person —</option>';
  salesPersons.forEach(sp=>{
    const opt=document.createElement('option');
    opt.value=sp.id;opt.textContent=sp.name+(sp.desig?' ('+sp.desig+')':'');
    sel.appendChild(opt);
  });
  if(cur) sel.value=cur;
}

document.getElementById('sel-sp').addEventListener('change',function(){
  const sp=salesPersons.find(s=>s.id===this.value);
  const box=document.getElementById('sp-preview-box');
  if(sp){
    const initials=sp.name.split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2);
    document.getElementById('sp-preview-avatar').textContent=initials;
    document.getElementById('sp-preview-avatar').style.background=sp.color;
    document.getElementById('sp-preview-name').textContent=sp.name+' — '+sp.desig;
    document.getElementById('sp-preview-phone').textContent=sp.phone||'';
    box.style.display='flex';
  } else { box.style.display='none'; }
});

