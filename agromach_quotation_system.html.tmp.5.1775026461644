function fmtN(n){return Math.round(n).toLocaleString('en-IN')}
function fmtINR(n){if(!n)return '₹0';return '₹'+Math.round(n).toLocaleString('en-IN')}
function fmtShort(n){if(!n)return '₹0';if(n>=10000000)return '₹'+(n/10000000).toFixed(1)+' Cr';if(n>=100000)return '₹'+(n/100000).toFixed(1)+' L';return '₹'+Math.round(n).toLocaleString('en-IN')}
function autoQNo(){const d=new Date();return `AEPL-${d.getFullYear()}${String(d.getMonth()+1).padStart(2,'0')}${String(d.getDate()).padStart(2,'0')}${Math.floor(1000+Math.random()*9000)}`}
function todayFmt(){const d=new Date();return `${String(d.getDate()).padStart(2,'0')}/${String(d.getMonth()+1).padStart(2,'0')}/${d.getFullYear()}`}

