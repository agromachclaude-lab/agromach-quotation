function renderDashboard(){
  const totalQ = savedQuotations.length;
  const totalVal = savedQuotations.reduce((s,q)=>s+q.totalAB,0);
  const wonQ = Math.floor(totalQ*0.6);
  document.getElementById('dash-stats').innerHTML=`
    <div class="stat-card"><div class="stat-label">Total Quotations</div><div class="stat-val">${totalQ}</div><div class="stat-sub">All time</div></div>
    <div class="stat-card"><div class="stat-label">Sales Team</div><div class="stat-val" style="color:var(--green)">${salesPersons.length}</div><div class="stat-sub">Active members</div></div>
    <div class="stat-card"><div class="stat-label">Open / Pending</div><div class="stat-val" style="color:var(--accent)">${Math.max(0,totalQ-wonQ)}</div><div class="stat-sub">Requires follow-up</div></div>
    <div class="stat-card"><div class="stat-label">Total Quoted Value</div><div class="stat-val" style="font-size:18px;color:var(--green)">${fmtShort(totalVal)}</div><div class="stat-sub">All quotations</div></div>`;

  if(!salesPersons.length){
    document.getElementById('sp-cards').innerHTML='<div style="grid-column:1/-1;text-align:center;padding:2rem;color:var(--text3);font-size:13px">No sales persons added yet. Go to <strong>Settings</strong> to add your team.</div>';
    return;
  }
  let cards='';
  salesPersons.forEach(sp=>{
    const spQuots = savedQuotations.filter(q=>q.spId===sp.id);
    const spVal = spQuots.reduce((s,q)=>s+q.totalAB,0);
    const initials = sp.name.split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2);
    cards+=`<div class="sp-card" onclick="showSpQuotations('${sp.id}')">
      <div class="sp-card-actions">
        <button class="icon-btn" onclick="event.stopPropagation();editSp('${sp.id}')" title="Edit">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        </button>
      </div>
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:14px">
        <div class="sp-avatar" style="background:${sp.color}">${initials}</div>
        <div>
          <div class="sp-name">${sp.name}</div>
          <div class="sp-desig">${sp.desig||'Sales Executive'}</div>
        </div>
      </div>
      <div class="sp-stats">
        <div class="sp-stat"><div class="sp-stat-val">${spQuots.length}</div><div class="sp-stat-label">Quotations</div></div>
        <div class="sp-stat"><div class="sp-stat-val" style="font-size:15px">${fmtShort(spVal)}</div><div class="sp-stat-label">Total Value</div></div>
      </div>
      ${sp.phone?`<div class="sp-phone">${sp.phone}</div>`:''}
    </div>`;
  });
  document.getElementById('sp-cards').innerHTML=cards;
}

function showSpQuotations(spId){
  const sp = salesPersons.find(s=>s.id===spId);
  if(!sp) return;
  const spQuots = savedQuotations.filter(q=>q.spId===spId);
  const initials = sp.name.split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2);
  document.getElementById('sp-quot-title').textContent=sp.name+"'s Quotations";
  document.getElementById('sp-quot-sub').innerHTML=`<span style="display:inline-flex;align-items:center;gap:6px"><span style="width:8px;height:8px;border-radius:50%;background:${sp.color};display:inline-block"></span>${sp.desig||'Sales Executive'} &nbsp;|&nbsp; ${spQuots.length} quotation(s)</span>`;
  const section = document.getElementById('sp-quot-section');
  section.style.display='block';
  if(!spQuots.length){
    document.getElementById('sp-quot-tbody').innerHTML='';
    document.getElementById('sp-quot-empty').style.display='block';
  } else {
    document.getElementById('sp-quot-empty').style.display='none';
    document.getElementById('sp-quot-tbody').innerHTML=[...spQuots].reverse().map(q=>`<tr>
      <td style="font-family:'IBM Plex Mono',monospace;font-size:12px;color:var(--text3)">${q.quotNo}</td>
      <td><strong>${q.custName}</strong><br><span style="font-size:11px;color:var(--text3)">${q.custLoc||''}</span></td>
      <td>${q.machineType}</td>
      <td style="font-family:'IBM Plex Mono',monospace;font-size:12px">${q.capacity} TPH</td>
      <td style="font-weight:600;color:var(--green)">${fmtINR(q.totalAB)}</td>
      <td style="font-size:12px;color:var(--text3)">${q.dateStr}</td>
      <td><button class="q-row-btn" onclick="viewSavedQuotation('${q.id}')">View / Open</button></td>
    </tr>`).join('');
  }
  section.scrollIntoView({behavior:'smooth'});
}

